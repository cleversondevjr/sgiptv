ACCESS_TOKEN=mercado_pago_access_token
ADMIN_USER=admin
ADMIN_PASS=troque_esta_senha
# Alternativa recomendada: use hash bcrypt em vez de ADMIN_PASS em texto puro.
# ADMIN_PASS_HASH=$2b$12$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
WEBHOOK_SECRET=troque_por_um_token_longo_aleatorio
WEBHOOK_NOTIFICATION_URL=https://sgiptv-backend.onrender.com/webhook

# Opcional: lista separada por virgula para liberar outras origens no CORS.
# FRONTEND_ORIGIN=https://sgiptv.com.br,https://www.sgiptv.com.br

# Opcional: duracao do teste gratis em horas. Padrao no codigo: 3.
# TESTE_DURACAO_HORAS=3

# Opcional: intervalo para novo teste gratis por email/WhatsApp. Padrao no codigo: 15.
# INTERVALO_TESTE_DIAS=15

# Opcional: prazo para pagamento do Pix em minutos. Padrao no codigo: 15.
# PIX_EXPIRACAO_MINUTOS=15

# Opcional: necessario apenas para envio de emails.
# EMAIL_USER=seu_email@gmail.com
# EMAIL_PASS=senha_de_app_do_gmail
